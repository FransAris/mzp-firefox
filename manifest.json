{
  "manifest_version": 3,
  "name": "Marktplaats Zonder Spam",
  "version": "0.1.0",
  "description": "Verbergt ongewenste Marktplaats- en 2dehands-resultaten zoals topadvertenties, Admarkt, banners en geblokkeerde verkopers.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "marktplaats-zonder-spam@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.marktplaats.nl/*",
        "https://www.2dehands.be/*"
      ],
      "css": ["src/content.css"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
