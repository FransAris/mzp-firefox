{
  "manifest_version": 3,
  "name": "Markplaats Zonder Spam V2",
  "version": "0.1.0",
  "description": "Verbergt ongewenste Marktplaats- en 2dehands-resultaten zoals topadvertenties, Admarkt, banners en geblokkeerde verkopers.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.marktplaats.nl/*",
        "https://www.2dehands.be/*"
      ],
      "css": ["src/content.css"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_title": "Markplaats Zonder Spam V2"
  }
}
